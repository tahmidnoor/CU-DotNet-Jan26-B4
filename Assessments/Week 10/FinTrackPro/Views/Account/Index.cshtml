@model List<FinTrackPro.Models.Account>

<div class="container mt-4">

    <h2 class="mb-3">Accounts</h2>

    <a asp-action="Create" class="btn btn-primary mb-3">Create Account</a>

    @foreach (var account in Model)
    {
        <div class="card mb-3">

            <div class="card-header">
                <strong>@account.AccountName</strong> (@account.Type)
            </div>

            <div class="card-body">

                <h6>Transactions</h6>

                @if (account.Transactions != null && account.Transactions.Count > 0)
                {
                    <table class="table table-bordered">

                        <tr>
                            <th>Description</th>
                            <th>Amount</th>
                            <th>Category</th>
                            <th>Date</th>
                        </tr>

                        @foreach (var t in account.Transactions)
                        {
                            <tr>
                                <td>@t.Description</td>
                                <td>@t.Amount</td>
                                <td>@t.Category</td>
                                <td>@t.Date.ToShortDateString()</td>
                            </tr>
                        }

                    </table>
                }
                else
                {
                    <p>No Transactions</p>
                }

            </div>

        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div id="toastMsg" class="toast show position-fixed bottom-0 end-0 m-3">

            <div class="toast-header bg-success text-white">
                <strong class="me-auto">Success</strong>
            </div>

            <div class="toast-body">
                @TempData["Success"]
            </div>

        </div>

        <script>
            setTimeout(function(){
                document.getElementById("toastMsg").style.display="none";
            },3000);
        </script>
    }

</div>