@{
    ViewData["Title"] = "LoanSphere";
}

<!-- HERO -->
<div class="ls-card ls-mb-8">

    <p class="ls-text-muted">Smart Loan Management Platform</p>

    <h1 style="font-size:2.5rem; font-weight:800;">
        Apply, Track & Manage Loans
        <span class="ls-text-primary">Seamlessly</span>
    </h1>

    <p class="ls-text-muted ls-mt-6" style="max-width:700px;">
        LoanSphere helps you apply for loans, track EMI schedules, and manage repayments —
        all in one secure platform.
    </p>

    <div class="ls-form-actions ls-mt-6">
        <a class="ls-btn ls-btn-primary ls-btn-lg"
               asp-controller="Account" asp-action="Register">
            Get Started
        </a>

        <a class="ls-btn ls-btn-secondary ls-btn-lg"
               asp-controller="Account" asp-action="Login">
            Login
        </a>
    </div>

</div>

<div class="ls-grid-3 ls-mb-8">

    <div class="ls-card">
        <h1 style="font-weight:800;">10K+</h1>
        <p class="ls-text-muted">Loans Processed</p>
    </div>

    <div class="ls-card">
        <h1 style="font-weight:800;">₹50Cr+</h1>
        <p class="ls-text-muted">Funds Disbursed</p>
    </div>

    <div class="ls-card">
        <h1 style="font-weight:800;">98%</h1>
        <p class="ls-text-muted">Customer Satisfaction</p>
    </div>

</div>

<!-- FEATURES -->
<div class="ls-grid-3 ls-mb-8">

    <div class="ls-card">
        <h3>Easy Loan Application</h3>
        <p class="ls-text-muted">
            Apply for loans in minutes with a simple and guided process.
        </p>
    </div>

    <div class="ls-card">
        <h3>Real-Time EMI Tracking</h3>
        <p class="ls-text-muted">
            Track payments, due dates, and remaining balance effortlessly.
        </p>
    </div>

    <div class="ls-card">
        <h3>Secure & Transparent</h3>
        <p class="ls-text-muted">
            Your data is protected with industry-grade security and full transparency.
        </p>
    </div>

</div>
<!-- PARTNERS -->
<div class="ls-card ls-mb-8">

    <h2 class="ls-mb-4">Capital Partners</h2>

    <div class="ls-grid-2">

        <div>
            <h4>Global Capital Fund</h4>
            <p class="ls-text-muted">Infrastructure & urban renewal</p>
            <span class="ls-tag">AUM $14.2B</span>
        </div>

        <div>
            <h4>Meridian Trust</h4>
            <p class="ls-text-muted">Commercial real estate</p>
            <span class="ls-tag">AUM $8.5B</span>
        </div>

    </div>

</div>

<!-- WORKFLOW -->
<div class="ls-card ls-mb-8">

    <h2 class="ls-mb-4">How It Works</h2>

    <div class="ls-grid-3">

        <div>
            <h4>1. Register</h4>
            <p class="ls-text-muted">Create your account in seconds.</p>
        </div>

        <div>
            <h4>2. Apply for Loan</h4>
            <p class="ls-text-muted">Fill details and submit your application.</p>
        </div>

        <div>
            <h4>3. Track & Repay</h4>
            <p class="ls-text-muted">Monitor EMI and make payments easily.</p>
        </div>

    </div>

</div>
<!-- CTA -->
<div class="ls-card">

    <h2>Start Your Loan Journey Today</h2>

    <p class="ls-text-muted ls-mb-6">
        Join thousands of users managing their loans smartly with LoanSphere.
    </p>

    <div class="ls-form-actions">
        <a class="ls-btn ls-btn-primary"
               asp-controller="Account" asp-action="Register">
            Create Free Account
        </a>

        <a class="ls-btn ls-btn-secondary"
               asp-controller="Account" asp-action="Login">
            Already have an account?
        </a>
    </div>

</div>