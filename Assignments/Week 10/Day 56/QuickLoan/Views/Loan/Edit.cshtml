@model QuickLoan.Models.Loan

<div class="container mt-4">
    <h2>Edit Loan</h2>

    <form asp-action="Edit" method="post" class="shadow p-4 rounded">

        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="BorrowerName" class="form-label"></label>
            <input asp-for="BorrowerName" class="form-control" />
            <span asp-validation-for="BorrowerName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="LenderName" class="form-label"></label>
            <input asp-for="LenderName" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Amount" class="form-label"></label>
            <input asp-for="Amount" class="form-control" />
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsSettled" class="form-check-input" />
            <label asp-for="IsSettled" class="form-check-label"></label>
        </div>

        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>