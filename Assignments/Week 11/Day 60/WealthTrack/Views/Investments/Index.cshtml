@model IEnumerable<WealthTrack.Models.Investment>

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h2>📈 My Portfolio</h2>
        <a asp-action="Create" class="btn btn-success">+ Add Investment</a>
    </div>

    <div class="card shadow p-3">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Ticker</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TickerSymbol</td>
                        <td>₹@item.PurchasePrice</td>
                        <td>@item.Quantity</td>
                        <td>@item.PurchaseDate.ToShortDateString()</td>
                        <td>₹@(item.PurchasePrice* item.Quantity)</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>