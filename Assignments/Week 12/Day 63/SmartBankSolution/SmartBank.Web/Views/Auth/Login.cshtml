@model SmartBank.Web.Models.LoginViewModel

<div class="auth-container">

    <div class="card auth-card p-4">

        <div class="text-center mb-4">
            <h3 class="fw-bold text-primary">SmartBank</h3>
            <p class="text-muted">Welcome back 👋</p>
        </div>

        <form asp-action="Login" method="post" onsubmit="handleLogin(this)">

            <!-- EMAIL -->
            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="Email" />
                <label>Email</label>
            </div>

            <!-- PASSWORD -->
            <div class="form-floating mb-3 position-relative">
                <input asp-for="Password" type="password" class="form-control" id="password" placeholder="Password" />
                <label>Password</label>

                <span class="toggle-password" onclick="togglePassword('password')">👁</span>
            </div>

            <!-- ERROR -->
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2">
                    @ViewBag.Error
                </div>
            }

            <!-- BUTTON -->
            <button type="submit" class="btn btn-primary w-100 mt-2" id="loginBtn">
                Login
            </button>

        </form>

        <div class="text-center mt-3">
            <small>New here? <a asp-action="Register">Create account</a></small>
        </div>

    </div>

</div>