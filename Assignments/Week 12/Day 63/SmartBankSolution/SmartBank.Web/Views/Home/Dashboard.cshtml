@model List<SmartBank.Web.Models.AccountViewModel>

@{
    ViewData["Title"] = "Dashboard";
    var totalBalance = Model.Sum(a => a.Balance);
}

<div class="container py-4">

    <!-- 🔥 HERO CARD -->
    <div class="hero-card text-white p-4 mb-4 fade-in">

        <div class="d-flex justify-content-between align-items-center">

            <div>
                <h6 class="mb-1">Total Balance</h6>
                <h2 class="fw-bold">
                    ₹ <span id="balanceCounter">@totalBalance</span>
                </h2>
                <small>@Model.Count Accounts</small>
            </div>

            <div class="fs-1">🪙</div>

        </div>

    </div>

    <!-- 🔥 QUICK ACTIONS -->
    <div class="mb-4">
        <h5 class="fw-semibold mb-3">Quick Actions</h5>

        <div class="row g-3">

            <div class="col-md-4">
                <a asp-controller="Accounts" asp-action="Index" class="text-decoration-none">
                    <div class="action-card text-center p-3 slide-up">
                        <div class="fs-3 mb-2">📊</div>
                        <div class="fw-semibold">View Accounts</div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Accounts" asp-action="Index" class="text-decoration-none">
                    <div class="action-card text-center p-3 slide-up">
                        <div class="fs-3 mb-2">💰</div>
                        <div class="fw-semibold">Deposit</div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Accounts" asp-action="Index" class="text-decoration-none">
                    <div class="action-card text-center p-3 slide-up">
                        <div class="fs-3 mb-2">💸</div>
                        <div class="fw-semibold">Withdraw</div>
                    </div>
                </a>
            </div>

        </div>
    </div>

    <!-- 🔥 RECENT TRANSACTIONS -->
    <div>
        <h5 class="fw-semibold mb-3">Recent Activity</h5>

        @{
            var recent = Model
                .SelectMany(a => a.Transactions ?? new List<SmartBank.Web.Models.TransactionViewModel>())
                .OrderByDescending(t => t.CreatedAt)
                .Take(6)
                .ToList();
        }

        @if (!recent.Any())
        {
            <p class="text-muted">No transactions yet</p>
        }
        else
        {
            <div class="card p-3 shadow-sm slide-up">

                @foreach (var t in recent)
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom transaction-row">

                        <div>
                            <div class="@(t.Type == "Deposit" ? "text-success" : "text-danger") fw-semibold">
                                @(t.Type == "Deposit" ? "↓ Received" : "↑ Sent")
                            </div>
                            <small class="text-muted">
                                @t.CreatedAt.ToString("dd MMM yyyy • hh:mm tt")
                            </small>
                        </div>

                        <div class="fw-semibold">
                            ₹ @t.Amount
                        </div>

                    </div>
                }

            </div>
        }

    </div>

    <!-- 🔥 CHART -->
    <div class="mt-5">
        <h5 class="fw-semibold mb-3">Balance Overview</h5>

        <div class="card p-3 shadow-sm slide-up">
            <canvas id="balanceChart" height="100"></canvas>
        </div>
    </div>

</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        // 🔥 DATA
        const accounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

        const labels = accounts.map(a => a.AccountNumber);
        const balances = accounts.map(a => a.Balance);

        // 🔥 CHART
        const ctx = document.getElementById('balanceChart');

        new Chart(ctx, {
        type: 'line',
        data: {
        labels: labels,
        datasets: [{
        data: balances,
        tension: 0.4,
        fill: true
        }]
        },
        options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
        y: { beginAtZero: true }
        }
        }
        });

        // 🔥 COUNT-UP ANIMATION
        function animateValue(id, start, end, duration) {

        let range = end - start;
        let current = start;
        let increment = end > start ? Math.ceil(range / 50) : -1;
        let stepTime = duration / 50;

        let obj = document.getElementById(id);

        let timer = setInterval(() => {
        current += increment;

        if (current >= end) {
        current = end;
        clearInterval(timer);
        }

        obj.innerText = current.toLocaleString();
        }, stepTime);
        }

        animateValue("balanceCounter", 0, @totalBalance, 800);

    </script>
}