@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<div class="container text-center py-5">

    <h1 class="fw-bold text-primary mb-3">SmartBank</h1>

    <p class="lead text-muted mb-4">
        Your smart way to manage money 💳
    </p>

    <div class="d-flex justify-content-center gap-3">
        <a class="btn btn-primary px-4" asp-controller="Auth" asp-action="Login">Login</a>
        <a class="btn btn-outline-primary px-4" asp-controller="Auth" asp-action="Register">Register</a>
    </div>

</div>

<!-- FEATURES -->
<div class="container py-5">

    <div class="row text-center g-4">

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>💼 Multiple Accounts</h5>
                <p class="text-muted small">Manage multiple bank accounts easily</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>📊 Track Transactions</h5>
                <p class="text-muted small">View all your transactions anytime</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>🔒 Secure</h5>
                <p class="text-muted small">JWT based secure authentication</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5>⚡ Fast</h5>
                <p class="text-muted small">Instant deposit & withdraw</p>
            </div>
        </div>

    </div>

</div>

<!-- CTA -->
<div class="text-center py-5">
    <h4 class="mb-3">Ready to get started?</h4>
    <a class="btn btn-success px-4" asp-controller="Auth" asp-action="Register">
        Create Account
    </a>
</div>